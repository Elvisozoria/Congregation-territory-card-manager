rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get user's congregation ID
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(congId) {
      return request.auth != null && getUserData().congregationId == congId;
    }

    function isAdminOf(congId) {
      return isMemberOf(congId) && getUserData().role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can update their own profile (e.g., change password flag)
      allow update: if request.auth != null && request.auth.uid == userId;
      // Admins can create/read users in their congregation
      allow create: if request.auth != null;
      // Admins can read all users in their congregation
      allow read: if request.auth != null
        && resource.data.congregationId == getUserData().congregationId
        && getUserData().role == 'admin';
    }

    // Congregations
    match /congregations/{congId} {
      allow read: if isMemberOf(congId);
      allow create: if request.auth != null;
      allow update, delete: if isAdminOf(congId);

      // Territories
      match /territories/{terId} {
        allow read: if isMemberOf(congId);
        allow create: if isMemberOf(congId);
        allow update: if isAdminOf(congId)
          || (isMemberOf(congId) && resource.data.assignedTo == request.auth.uid);
        allow delete: if isAdminOf(congId);
      }

      // History
      match /history/{histId} {
        allow read: if isMemberOf(congId);
        allow create: if isMemberOf(congId);
        allow update, delete: if isMemberOf(congId);
      }
    }
  }
}
