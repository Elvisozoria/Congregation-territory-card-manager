rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(congId) {
      return request.auth != null && getUserData().congregationId == congId;
    }

    function isAdminOf(congId) {
      return isMemberOf(congId) && getUserData().role == 'admin';
    }

    function isConductorOf(congId) {
      return isMemberOf(congId) && getUserData().role == 'conductor';
    }

    function isPublisherOf(congId) {
      return isMemberOf(congId) && getUserData().role == 'publisher';
    }

    // Admin o conductor (rol con lectura general)
    function isStaffOf(congId) {
      return isAdminOf(congId) || isConductorOf(congId);
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Users can only create their OWN profile (registration flow)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can update their own profile BUT cannot change role or congregationId
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'congregationId']);

      // Admins can read users in their congregation
      allow read: if request.auth != null
        && resource.data.congregationId == getUserData().congregationId
        && getUserData().role == 'admin';

      // Admins can create users in their congregation (for the secondary-app pattern)
      allow create: if request.auth != null
        && getUserData().role == 'admin'
        && request.resource.data.congregationId == getUserData().congregationId;

      // Admins can update users in their congregation (e.g., change role)
      allow update: if request.auth != null
        && resource.data.congregationId == getUserData().congregationId
        && getUserData().role == 'admin';

      // Conductor / publisher pueden leer otros perfiles de su congregación
      // (necesario para mostrar nombres en historial / dropdown)
      allow read: if request.auth != null
        && resource.data.congregationId == getUserData().congregationId;
    }

    // Invites (for Google auth invite flow)
    match /invites/{inviteId} {
      // Any authenticated user can read invites (to check their own email)
      allow read: if request.auth != null;
      // Only admins can create invites
      allow create: if request.auth != null && getUserData().role == 'admin';
      // Users can delete invites (consumed on sign-in)
      allow delete: if request.auth != null;
    }

    // Lookup table for public territory links (anyone can read by publicId)
    match /publicLinks/{linkId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Congregations
    match /congregations/{congId} {
      // Miembros leen todo; visitantes anónimos leen si la congregación tiene publicId
      allow read: if isMemberOf(congId) || resource.data.publicId != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdminOf(congId);

      // Territories
      match /territories/{terId} {
        // Miembros leen siempre; visitantes anónimos leen si el territorio tiene publicId
        allow read: if isMemberOf(congId) || resource.data.publicId != null;
        // Solo admin crea/edita/borra (incluye polígono, notas, landmarks, blocks, cardZoom)
        allow create: if isAdminOf(congId);
        allow update: if isAdminOf(congId);
        allow delete: if isAdminOf(congId);
      }

      // History
      match /history/{histId} {
        allow read: if isStaffOf(congId)
          || (isPublisherOf(congId) && resource.data.assignedToUid == request.auth.uid);

        // Crear asignaciones: solo admin
        allow create: if isAdminOf(congId);

        // Actualizar: admin cualquier cosa; conductor/publisher solo su propia entrada
        // y solo pueden cambiar status/endDate/notes (no person, no tipo, no asignación)
        allow update: if isAdminOf(congId)
          || (isMemberOf(congId)
              && resource.data.assignedToUid == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['status', 'endDate', 'notes']));

        // Borrar: solo admin
        allow delete: if isAdminOf(congId);
      }

      // Global Landmarks — solo admin escribe
      match /globalLandmarks/{lmId} {
        allow read: if isMemberOf(congId);
        allow create, update, delete: if isAdminOf(congId);
      }
    }
  }
}
